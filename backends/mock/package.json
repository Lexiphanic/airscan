{
  "name": "@airscan/backend-mock",
  "module": "src/index.ts",
  "scripts": {
    "lint": "bun run lint:tsc && bun run lint:biome",
    "lint:tsc": "bunx tsc -b",
    "lint:biome": "bun run biome lint",
    "lint:fix": "bun run lint --fix",
    "format": "bun run biome format",
    "format:fix": "bun run format --fix",
    "dev": "bun ./src/index.ts",
    "build": "bun build --production --compile ./src/index.ts --outfile ./dist/airscan-backend-mock"
  },
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@airscan/websockets": "workspace:*",
    "@airscan/types": "workspace:*",
    "@faker-js/faker": "^9.6.0",
    "meow": "^14.1.0"
  }
}
