{
  "name": "@airscan/web",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/main.tsx",
  "scripts": {
    "lint": "bunx tsc -b",
    "dev": "vite --host 0.0.0.0",
    "build": "bunx tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "install:playwright": "bun playwright install --with-deps chromium-headless-shell",
    "test": "bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:start-servers": "bun run dev & (cd ../../backends/mock/ && bun run dev)"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/dom-serial": "^1.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.2",
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}